{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "skips_all_branches": {
      "type": "array",
      "items": { "$ref": "#/definitions/global_entry" }
    },
    "skips": {
      "type": "array",
      "items": { "$ref": "#/definitions/branch_entry" }
    },
    "reset_branches": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "definitions": {
    "base_fields": {
      "type": "object",
      "required": ["name", "reason", "owner"],
      "properties": {
        "name":   { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "owner":  { "type": "string", "minLength": 1 },
        "note":   { "type": "string" }
      }
    },
    "global_entry": {
      "allOf": [{ "$ref": "#/definitions/base_fields" }],
      "additionalProperties": false,
      "properties": {
        "name": {}, "reason": {}, "owner": {}, "note": {}
      }
    },
    "branch_entry": {
      "allOf": [{ "$ref": "#/definitions/base_fields" }],
      "required": ["name", "reason", "owner", "branches"],
      "additionalProperties": false,
      "properties": {
        "name": {}, "reason": {}, "owner": {}, "note": {},
        "branches": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        }
      }
    }
  }
}
